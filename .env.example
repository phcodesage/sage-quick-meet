# Backend/WebSocket URL Configuration
# ==========================================
# For LOCAL DEVELOPMENT, use:
# NEXT_PUBLIC_WS_URL=ws://localhost:3001

# For PRODUCTION DEPLOYMENT (Vercel), use:
NEXT_PUBLIC_WS_URL=wss://sage-quick-meet.onrender.com

# HTTP API URL (optional - if not set, will be derived from the current origin)
